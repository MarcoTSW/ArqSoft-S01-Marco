@model Catalogo.Models.Item

<h1>@Model.Titulo</h1>

<!-- ===================== -->
<!-- Información del videojuego -->
<!-- ===================== -->
<div>
    <p>
        <strong>Género:</strong> @Model.Genero
    </p>

    <p>
        <strong>Consola:</strong> @Model.Consola
    </p>

    <p>
        <strong>Año:</strong> @Model.Ano
    </p>

